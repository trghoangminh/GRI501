# ============================================================
# AI Study Planner — Environment Variables
# Copy file này thành .env và điền thông tin của bạn vào
# KHÔNG commit file .env lên Git!
# ============================================================

# ------ Database (Supabase) ------
# Lấy tại: Supabase Dashboard > Settings > Database > URI (Direct connection)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ------ Google Gemini AI ------
# Lấy tại: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=

# ------ JWT Auth ------
# Tạo ngẫu nhiên: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-key-min-32-chars-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ------ Google OAuth (tùy chọn) ------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------ CORS ------
FRONTEND_URL=http://localhost:5173

# ------ Email (tùy chọn) ------
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@studyplanner.com

# ------ File Storage ------
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ------ Qdrant Vector Store (local) ------
QDRANT_PATH=./qdrant_storage
