# ============================================================
# Frontend .gitignore — React / Vite / TypeScript
# ============================================================

# ---- Secrets ----
.env
.env.*
!.env.example

# ---- Dependencies ----
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ---- Build output ----
dist/
dist-ssr/
build/
out/

# ---- Cache ----
.cache/
.parcel-cache/
.vite/
.turbo/

# ---- Logs ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---- Testing ----
coverage/
.nyc_output/

# ---- TypeScript ----
*.tsbuildinfo

# ---- Editor ----
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---- macOS ----
.DS_Store
*.local

# ---- Storybook (nếu dùng) ----
storybook-static/
